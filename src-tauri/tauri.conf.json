{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "mirabilis",
  "version": "0.1.0",
  "identifier": "me.mizorewww.mirabilis",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "mirabilis",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "desktopTemplate": "linux/desktop-template.desktop",
        "files": {
          "/usr/share/icons/hicolor/scalable/apps/mirabilis.svg": "../public/Mirabilis.svg"
        }
      },
      "rpm": {
        "desktopTemplate": "linux/desktop-template.desktop",
        "files": {
          "/usr/share/icons/hicolor/scalable/apps/mirabilis.svg": "../public/Mirabilis.svg"
        }
      }
    }
  }
}
